{
  "keyboard.dispatch": "keyCode",
  "editor.fontLigatures": true,
  "editor.fontFamily": "'JetBrainsMono Nerd Font', 'Droid Sans Mono', 'monospace', monospace",
  "editor.fontSize": 16,
  "editor.codeLensFontFamily": "'JetBrainsMono Nerd Font'",
  "editor.inlayHints.fontFamily": "'JetBrainsMono Nerd Font'",
  "terminal.integrated.fontFamily": "'JetBrainsMono Nerd Font'",
  "editor.formatOnSave": true,
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "editor.rulers": [88],
  "[vue]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "typescript.updateImportsOnFileMove.enabled": "always",
  "python.formatting.provider": "black",
  "python.languageServer": "Pylance",
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "python.analysis.typeCheckingMode": "basic",
  "trailing-spaces.trimOnSave": true,
  "[python]": {
    "editor.formatOnType": true,
    "editor.defaultFormatter": "ms-python.black-formatter",
  },
  "rust-analyzer.inlayHints.parameterHints.enable": false,
  "rust-analyzer.inlayHints.typeHints.enable": false,
  "editor.wordWrap": "on",
  "prettier.trailingComma": "all",
  "python.analysis.autoImportCompletions": true,
  "github.copilot.advanced": {},
  "github.copilot.enable": {
    "COBOL_MF_LISTFILE": false,
    "COBOL_PCOB_LISTFILE": false,
    "COBOL_ACU_LISTFILE": false,
    "COBOL_MF_PREP": false,
    "mfu": false,
    "utreport": false,
    "typescript": true,
    "RMCOBOL": false,
    "ACUCOBOL": false,
    "BITLANG-COBOL": false,
    "ILECOBOL": false,
    "COBOL": false,
    "COBOLIT": false,
  },
  "docker.extension.enableComposeLanguageServer": false,
  "github.copilot.nextEditSuggestions.enabled": true,
  "extensions.experimental.affinity": {
    "asvetliakov.vscode-neovim": 1,
  },
  "[dockercompose]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.autoIndent": "advanced",
    "editor.quickSuggestions": {
      "other": true,
      "comments": false,
      "strings": true,
    },
    "editor.defaultFormatter": "redhat.vscode-yaml",
  },
  "[github-actions-workflow]": {
    "editor.defaultFormatter": "redhat.vscode-yaml",
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "chat.tips.enabled": false,
  "workbench.colorTheme": "Dracula Theme",
  "workbench.view.showQuietly": {
    "workbench.panel.output": true
  }
}
